          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Parafuso M8 x 50mm\",\n  \"category\": \"Ferragens\",\n  \"codigo\": \"PAR-M8-50\",\n  \"serial_number\": \"SN123456\",\n  \"minimal_quantity\": 20,\n  \"quantity\": 100,\n  \"value\": 0.50,\n  \"local_storage\": \"Prateleira A1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": ["{{base_url}}"],
              "path": ["api", "products"]
