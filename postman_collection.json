            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"inbound\",\n  \"product_id\": \"{{product_id}}\",\n  \"movimented_by\": 12345,\n  \"quantity\": 50,\n  \"local_storage\": \"Prateleira A1\",\n  \"appointment\": \"Recebimento de compra fornecedor XYZ\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/movimentations",
              "host": ["{{base_url}}"],
              "path": ["api", "movimentations"]
