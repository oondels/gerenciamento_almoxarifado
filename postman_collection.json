              "mode": "raw",
              "raw": "{\n  \"type\": \"outbound\",\n  \"product_id\": \"{{product_id}}\",\n  \"movimented_by\": 12345,\n  \"quantity\": 20,\n  \"appointment\": \"Saída para obra 123\"\n}"
